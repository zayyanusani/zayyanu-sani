rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - selectedCourseId: string (optional)
    //   - enrolledAt: string (optional)
    //
    // Collection: courses
    // Document ID: {courseId}
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - description: string (optional)
    //   - youtubeUrl: string (required)
    //   - thumbnail: string (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('selectedCourseId' in data) || data.selectedCourseId is string);
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['id', 'title', 'youtubeUrl']) &&
             data.id is string &&
             data.title is string &&
             data.youtubeUrl is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin (manual) can write courses for now
    }
  }
}
